{
  "name": "@peerclaw/openclaw-plugin",
  "version": "0.1.0",
  "description": "OpenClaw channel plugin for PeerClaw P2P agent identity and trust",
  "type": "module",
  "scripts": {
    "test": "vitest run"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "vitest": "^3.1.0",
    "typescript": "^5.8.0"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "channel": {
      "id": "peerclaw",
      "label": "PeerClaw",
      "selectionLabel": "PeerClaw (P2P Agent Network)",
      "docsPath": "/channels/peerclaw",
      "docsLabel": "peerclaw",
      "blurb": "P2P agent identity and trust platform with Ed25519 identities.",
      "order": 60,
      "quickstartAllowFrom": true
    },
    "install": {
      "npmSpec": "@peerclaw/openclaw-plugin",
      "defaultChoice": "npm"
    }
  },
  "files": [
    "index.ts",
    "src/",
    "openclaw.plugin.json",
    "LICENSE",
    "README.md",
    "README_zh.md"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/peerclaw/openclaw-plugin.git"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "peerclaw",
    "p2p",
    "agent",
    "identity",
    "trust",
    "ed25519"
  ]
}
